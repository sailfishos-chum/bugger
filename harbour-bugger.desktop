[Desktop Entry]
Type=Application
Icon=harbour-bugger
X-Nemo-Application-Type=silica-qt5
Exec=/usr/bin/invoker --type=silica-qt5 /usr/bin/sailfish-qml harbour-bugger
Name=Bugger!
Name[en]=Bugger!
Name[de]=Bugger!
Name[sv]=Bugger!

X-Maemo-Service=sailfishos-chum.Bugger
X-Maemo-Object-Path=/ui
X-Maemo-Method=sailfishos-chum.Bugger.newBug


[X-Sailjail]
ApplicationName=Bugger
OrganizationName=sailfishos-chum
Permissions=Documents,Email
